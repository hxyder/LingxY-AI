{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uca.local/schemas/task.schema.json",
  "title": "Task",
  "type": "object",
  "required": [
    "task_id",
    "created_at",
    "updated_at",
    "status",
    "intent",
    "executor",
    "user_command",
    "context_packet",
    "execution_mode"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "awaiting_confirmation",
        "queued",
        "starting",
        "running",
        "streaming",
        "success",
        "partial_success",
        "failed",
        "cancelled",
        "interrupted",
        "pending_approval"
      ]
    },
    "sub_status": { "type": ["string", "null"] },
    "intent": { "type": "string", "minLength": 1 },
    "executor": { "type": "string", "minLength": 1 },
    "user_command": { "type": "string", "minLength": 1 },
    "execution_mode": {
      "type": "string",
      "enum": ["interactive", "unattended_safe", "approval_required"]
    },
    "priority": {
      "type": "string",
      "enum": ["high", "normal", "background"]
    },
    "context_packet": { "$ref": "./context_packet.schema.json" },
    "requires_confirmation": { "type": "boolean" },
    "failure_category": { "type": ["string", "null"] },
    "retryable": { "type": "boolean" },
    "parent_task_id": { "type": ["string", "null"] },
    "child_task_ids": {
      "type": ["array", "null"],
      "items": { "type": "string", "minLength": 1 }
    },
    "child_index": { "type": ["integer", "null"], "minimum": 0 },
    "progress": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}

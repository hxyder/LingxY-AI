{
  "schema_version": "1.0",
  "kind": "tools",
  "provider": "google",
  "service": "google.gmail",
  "tools": [
    {
      "id": "google.gmail.create_draft_preview",
      "mcpName": "gmail_create_draft_preview",
      "name": "Gmail Create Draft Preview",
      "description": "Create a local non-sending Gmail draft preview for user review before any send action.",
      "capability": "emailWrite",
      "risk": "low",
      "requiresConfirmation": false,
      "source": "internal_connector",
      "execution": {
        "kind": "local_preview"
      },
      "inputSchema": {
        "type": "object",
        "required": [
          "to",
          "subject",
          "body"
        ],
        "properties": {
          "accountId": { "type": "string" },
          "to": {
            "type": "array",
            "items": { "type": "string", "format": "email" },
            "minItems": 1
          },
          "cc": {
            "type": "array",
            "items": { "type": "string", "format": "email" }
          },
          "bcc": {
            "type": "array",
            "items": { "type": "string", "format": "email" }
          },
          "subject": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "draft_preview",
          "subject",
          "body",
          "pending_confirmation"
        ],
        "properties": {
          "draft_preview": { "type": "string" },
          "subject": { "type": "string" },
          "body": { "type": "string" },
          "pending_confirmation": { "type": "boolean" }
        }
      },
      "outputValidators": [
        { "path": "draft_preview", "kind": "nonempty_string" },
        { "path": "subject", "kind": "nonempty_string" },
        { "path": "body", "kind": "nonempty_string" },
        { "path": "pending_confirmation", "kind": "pending_confirmation" }
      ],
      "timeline": {
        "label": "Gmail draft preview",
        "payloadPolicy": "summary_only"
      }
    },
    {
      "id": "google.gmail.list_emails",
      "mcpName": "gmail_list_emails",
      "name": "Gmail List Emails",
      "description": "List recent or matching email metadata from a connected Gmail account.",
      "capability": "emailRead",
      "risk": "low",
      "requiresConfirmation": false,
      "source": "internal_connector",
      "execution": {
        "actionTool": "account_list_emails",
        "provider": "google"
      },
      "inputSchema": {
        "type": "object",
        "required": [],
        "properties": {
          "accountId": { "type": "string" },
          "query": { "type": "string" },
          "unreadOnly": { "type": "boolean" },
          "limit": { "type": "number", "minimum": 1, "maximum": 100 }
        }
      },
      "outputValidators": [
        { "path": "emails", "kind": "array_min_items", "min": 0 }
      ],
      "timeline": {
        "label": "Gmail email search",
        "payloadPolicy": "summary_only"
      }
    },
    {
      "id": "google.gmail.send_email",
      "mcpName": "gmail_send_email",
      "name": "Gmail Send Email",
      "description": "Send an email through a connected Gmail account after explicit user confirmation. Supports file attachments via attachmentPaths (absolute local paths).",
      "capability": "emailWrite",
      "risk": "high",
      "requiresConfirmation": true,
      "source": "internal_connector",
      "execution": {
        "actionTool": "account_send_email",
        "provider": "google"
      },
      "inputSchema": {
        "type": "object",
        "required": [
          "to",
          "subject",
          "body"
        ],
        "properties": {
          "accountId": { "type": "string" },
          "to": {
            "type": "array",
            "items": { "type": "string", "format": "email" },
            "minItems": 1
          },
          "cc": {
            "type": "array",
            "items": { "type": "string", "format": "email" }
          },
          "bcc": {
            "type": "array",
            "items": { "type": "string", "format": "email" }
          },
          "subject": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 },
          "attachmentPaths": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Absolute local file paths to attach."
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "sent"
        ],
        "properties": {
          "sent": { "type": "boolean" },
          "messageId": { "type": "string" }
        }
      },
      "outputValidators": [
        { "path": "sent", "kind": "boolean_true" }
      ],
      "timeline": {
        "label": "Gmail send email",
        "payloadPolicy": "summary_only"
      }
    }
  ]
}

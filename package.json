  },
  "build": {
    "appId": "com.uca.desktop",
    "productName": "LingxY",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.cjs",
      "src/**/*",
      "office_addin/shared/**/*",
      "scripts/*.ps1",
      "scripts/*.mjs",
      "scripts/*.py",
      "uca-native-host/**/*",
      "browser_ext/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LingxY"
    },
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "*.ps1",
          "*.mjs",
          "*.py"
        ]
      }
    ]
  }

{
  "name": "universal-context-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.cjs",
  "description": "Universal Context Agent desktop runtime for Windows.",
  "author": "UCA Contributors",
  "scripts": {
    "check": "node scripts/verify-structure.mjs && node scripts/verify-desktop-shell.mjs && node scripts/verify-desktop-renderer.mjs && node scripts/verify-overlay-composer.mjs && node scripts/verify-context-handoff-ui.mjs && node scripts/verify-console-ui.mjs && node scripts/verify-console-runtime-client.mjs && node scripts/verify-console-rendered-workspace.mjs && node scripts/verify-service-core.mjs && node scripts/verify-provider-health.mjs && node scripts/verify-provider-routing.mjs && node scripts/verify-ai-integrations.mjs && node scripts/verify-agentic-planner.mjs && node scripts/verify-active-window-probe.mjs && node scripts/verify-file-kimi.mjs && node scripts/verify-kimi-runtime.mjs && node scripts/verify-browser-extension.mjs && node scripts/verify-browser-overlay.mjs && node scripts/verify-page-source-extractor.mjs && node scripts/verify-page-explain-handoff.mjs && node scripts/verify-office-base.mjs && node scripts/verify-pdf-ocr.mjs && node scripts/verify-status-metrics.mjs && node scripts/verify-action-tools.mjs && node scripts/verify-security-broker.mjs && node scripts/verify-scheduler.mjs && node scripts/verify-platform-foundation.mjs && node scripts/verify-template-dag-persistence.mjs && node scripts/verify-runtime-wiring.mjs && node scripts/verify-native-integrations.mjs && node scripts/verify-email-monitoring.mjs && node scripts/verify-email-morning-digest.mjs && node scripts/verify-release-readiness.mjs",
    "build:trial-package": "node scripts/build-trial-package.mjs",
    "start:desktop": "node scripts/start-desktop.mjs",
    "start:runtime": "node scripts/start-runtime.mjs",
    "verify:structure": "node scripts/verify-structure.mjs",
    "verify:desktop-shell": "node scripts/verify-desktop-shell.mjs",
    "verify:desktop-renderer": "node scripts/verify-desktop-renderer.mjs",
    "verify:overlay-composer": "node scripts/verify-overlay-composer.mjs",
    "verify:context-handoff-ui": "node scripts/verify-context-handoff-ui.mjs",
    "verify:console-ui": "node scripts/verify-console-ui.mjs",
    "verify:console-runtime-client": "node scripts/verify-console-runtime-client.mjs",
    "verify:console-rendered-workspace": "node scripts/verify-console-rendered-workspace.mjs",
    "verify:service-core": "node scripts/verify-service-core.mjs",
    "verify:provider-health": "node scripts/verify-provider-health.mjs",
    "verify:provider-routing": "node scripts/verify-provider-routing.mjs",
    "verify:ai-integrations": "node scripts/verify-ai-integrations.mjs",
    "verify:agentic-planner": "node scripts/verify-agentic-planner.mjs",
    "verify:file-kimi": "node scripts/verify-file-kimi.mjs",
    "verify:kimi-runtime": "node scripts/verify-kimi-runtime.mjs",
    "verify:browser-extension": "node scripts/verify-browser-extension.mjs",
    "verify:browser-overlay": "node scripts/verify-browser-overlay.mjs",
    "verify:office-base": "node scripts/verify-office-base.mjs",
    "verify:pdf-ocr": "node scripts/verify-pdf-ocr.mjs",
    "verify:status-metrics": "node scripts/verify-status-metrics.mjs",
    "verify:action-tools": "node scripts/verify-action-tools.mjs",
    "verify:security-broker": "node scripts/verify-security-broker.mjs",
    "verify:scheduler": "node scripts/verify-scheduler.mjs",
    "verify:platform-foundation": "node scripts/verify-platform-foundation.mjs",
    "verify:template-dag-persistence": "node scripts/verify-template-dag-persistence.mjs",
    "verify:runtime-wiring": "node scripts/verify-runtime-wiring.mjs",
    "verify:native-integrations": "node scripts/verify-native-integrations.mjs",
    "verify:email-monitoring": "node scripts/verify-email-monitoring.mjs",
    "verify:email-morning-digest": "node scripts/verify-email-morning-digest.mjs",
    "verify:release-readiness": "node scripts/verify-release-readiness.mjs",
    "verify:trial-launch": "node scripts/verify-trial-launch.mjs",
    "verify:page-source-extractor": "node scripts/verify-page-source-extractor.mjs",
    "verify:page-explain-handoff": "node scripts/verify-page-explain-handoff.mjs",
    "licenses": "node scripts/generate-third-party-licenses.mjs",
    "pack": "node scripts/run-electron-builder.mjs --dir --config.win.signAndEditExecutable=false",
    "dist": "node scripts/run-electron-builder.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/server-brave-search": "^0.6.2",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@modelcontextprotocol/server-memory": "^2026.1.26",
    "@modelcontextprotocol/server-puppeteer": "^2025.5.12",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^11.10.0",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "linkedom": "^0.18.12",
    "mermaid": "^11.14.0",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "electron": "^35.3.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.uca.desktop",
    "productName": "UCA",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.cjs",
      "src/**/*",
      "office_addin/shared/**/*",
      "scripts/*.ps1",
      "scripts/*.mjs",
      "scripts/*.py",
      "uca-native-host/**/*",
      "browser_ext/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "UCA"
    },
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "*.ps1",
          "*.mjs",
          "*.py"
        ]
      }
    ]
  }
}

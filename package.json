          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LingxY"
    },
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "*.ps1",
          "*.mjs",
          "*.py"
        ]
      }

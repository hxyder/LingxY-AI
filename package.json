{
  "name": "lingxy-ai-desktop",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "index.cjs",
  "description": "LingxY AI desktop runtime for Windows.",
  "author": "LingxY AI Contributors <hxy94045@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "start:runtime": "node scripts/start-runtime.mjs",
    "start:desktop": "node scripts/start-desktop.mjs",
    "mcp:server": "node scripts/start-lingxy-mcp-server.mjs",
    "inspect:routing": "node scripts/inspect-routing.mjs",
    "test": "node --test tests/behavior/success-contract-validation-spec.test.mjs tests/behavior/tool-call-validator-side-effect.test.mjs",
    "smoke:runtime": "node scripts/smoke-runtime-health.mjs",
    "smoke:desktop": "node scripts/smoke-desktop-entrypoints.mjs",
    "smoke:ui-i18n": "node scripts/smoke-ui-i18n.mjs",
    "check:public": "node scripts/check-public.mjs",
    "prepare:release-oauth": "node scripts/prepare-release-oauth-clients.mjs",
    "prepare:native-host-release": "node scripts/prepare-native-host-release.mjs",
    "licenses": "node scripts/generate-third-party-licenses.mjs",
    "pack": "node scripts/run-electron-builder.mjs --dir --config.win.signAndEditExecutable=false",
    "dist": "node scripts/run-electron-builder.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@modelcontextprotocol/server-memory": "^2026.1.26",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.10.0",
    "docx": "^9.6.1",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "imapflow": "^1.3.3",
    "linkedom": "^0.18.12",
    "mammoth": "^1.12.0",
    "mermaid": "^11.15.0",
    "opencc-js": "^1.3.1",
    "pdfjs-dist": "^4.10.38",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "electron": "^39.8.10",
    "electron-builder": "^26.0.0"
  },
  "overrides": {
    "unzipper": "0.12.3"
  },
  "build": {
    "appId": "com.uca.desktop",
    "productName": "LingxY",
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "LICENSE",
      "THIRD_PARTY_LICENSES.md",
      "index.cjs",
      "src/**/*",
      "office_addin/shared/**/*",
      "uca-native-host/**/*",
      "browser_ext/**/*",
      "scripts/start-runtime.mjs",
      "scripts/start-desktop.mjs",
      "scripts/start-lingxy-mcp-server.mjs",
      "scripts/local-sherpa-kws.py",
      "scripts/local-whisper-transcribe.py",
      "scripts/capture-screenshot.ps1",
      "scripts/capture-context.ps1",
      "scripts/active-window-probe.ps1",
      "scripts/install-native-host.ps1",
      "scripts/render-document.ps1",
      "scripts/ocr-image.ps1",
      "scripts/setup-office-addins.ps1",
      "scripts/app_launcher/**/*",
      "!scripts/app_launcher/__pycache__/**",
      "assets/icons/**/*"
    ],
    "win": {
      "icon": "assets/icons/lingxy.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "lingxy-ai",
      "repo": "lingxy-desktop"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LingxY",
      "installerIcon": "assets/icons/lingxy.ico",
      "uninstallerIcon": "assets/icons/lingxy.ico"
    },
    "extraResources": [
      {
        "from": ".tmp/release/oauth-clients.json",
        "to": "oauth-clients.json"
      },
      {
        "from": "external/local-speech-runtime",
        "to": "local-speech"
      },
      {
        "from": "browser_ext",
        "to": "browser_ext"
      },
      {
        "from": "office_addin",
        "to": "office_addin"
      },
      {
        "from": ".tmp/release/native-host/win-x64",
        "to": "uca-native-host"
      },
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "start-runtime.mjs",
          "start-desktop.mjs",
          "start-lingxy-mcp-server.mjs",
          "local-sherpa-kws.py",
          "local-whisper-transcribe.py",
          "install-native-host.ps1",
          "capture-screenshot.ps1",
          "capture-context.ps1",
          "active-window-probe.ps1",
          "render-document.ps1",
          "ocr-image.ps1",
          "setup-office-addins.ps1",
          "app_launcher/**/*",
          "!app_launcher/__pycache__/**"
        ]
      }
    ]
  }
}
